{
  "name": "@seahax/elemental",
  "version": "0.1.0",
  "private": true,
  "description": "Extremely minimal reactive custom elements library.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seahax/workshop.git",
    "directory": "packages/elemental"
  },
  "license": "Unlicense",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -b -f tsconfig.lib.json",
    "clean": "rm -rf dist",
    "diff": "npm run build >/dev/null && npm diff 'dist/**.mjs' 'dist/**.cjs' 'dist/**.js' 'dist/**.d.ts'",
    "test": "eslint src && vitest run --coverage",
    "start": "vite dev"
  },
  "devDependencies": {
    "@seahax/eslint": "^0.2.27",
    "@seahax/vite-plugin-lib": "^0.8.7",
    "@seahax/vitest": "^0.1.8",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.4",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@tabler/icons": "^3.41.1",
    "@tabler/icons-webfont": "^3.36.0"
  }
}
